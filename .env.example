# Blender executable. Leave unset if `blender` is available on PATH.
STORYBLENDER_BLENDER_EXE=

# Story asset root. The repository does not include story assets.
LBM_SCRIPTS_ROOT=
LBM_DEMO_ROOT=
LBM_PYTHON_EXE=

# VLM endpoint used by Director/Cinematographer.
ANYLLM_API_KEY=
ANYLLM_API_BASE=
ANYLLM_PROVIDER=openai
STORYBLENDER_VISION_MODEL=

# CineStoryEval model assets.
CINESTORY_QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
CINESTORY_QWEN_CACHE_DIR=Evaluation/models/huggingface
CINESTORY_YOLO_WEIGHTS=Evaluation/models/yolo/yolo11x.pt
